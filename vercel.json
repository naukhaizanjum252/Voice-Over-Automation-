{
  "crons": [
    {
      "path": "/api/cron/process?secret=${CRON_SECRET}",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/process/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/channel/run/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/channel/run-all/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/card/retry/route.ts": {
      "maxDuration": 300
    }
  }
}
